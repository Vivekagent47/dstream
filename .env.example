# Server
DSTREAM_HTTP_ADDR=:8080
DSTREAM_LOG_LEVEL=info
DSTREAM_LOG_FORMAT=json
DSTREAM_PUBLIC_BASE_URL=http://localhost:8080

# Dev only: log magic-link + invite tokens to stdout so you can sign in without
# SMTP. MUST be false in production — the server refuses to boot with this true
# unless PUBLIC_BASE_URL is localhost.
DSTREAM_DEV_MODE=true

# Postgres
DSTREAM_DB_URL=postgres://dstream:dstream@localhost:5432/dstream?sslmode=disable
DSTREAM_DB_MAX_CONNS=20

# Redis (queue + rate limit + cache)
DSTREAM_REDIS_ADDR=localhost:6379
DSTREAM_REDIS_PASSWORD=
DSTREAM_REDIS_DB=0

# Worker
DSTREAM_WORKER_CONCURRENCY=50

# Ingest rate limit (per source, token bucket). 0 disables; burst defaults 2x rps.
DSTREAM_INGEST_RATE_LIMIT_RPS=100
DSTREAM_INGEST_RATE_LIMIT_BURST=200

# Auth
DSTREAM_SESSION_SECRET=change-me-32-bytes-minimum-please-use-openssl-rand
DSTREAM_MAGIC_LINK_TTL=15m
# Session/CSRF cookies are Secure by default. Set to false ONLY for local HTTP
# dev; the server refuses to boot with a non-localhost PUBLIC_BASE_URL when false.
DSTREAM_COOKIE_SECURE=false

# Delivery / SSRF
# Outbound delivery blocks loopback/private/link-local (cloud metadata) targets
# by default. Set true ONLY on trusted self-host setups that deliver to private
# ranges. NEVER enable on a multi-tenant/SaaS deployment.
DSTREAM_ALLOW_PRIVATE_DESTINATIONS=false

# SMTP (magic-link email; logs to stdout if blank in dev)
DSTREAM_SMTP_HOST=
DSTREAM_SMTP_PORT=587
DSTREAM_SMTP_USER=
DSTREAM_SMTP_PASS=
DSTREAM_SMTP_FROM=noreply@localhost
